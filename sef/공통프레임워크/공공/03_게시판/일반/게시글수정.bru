meta {
  name: 게시글수정
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/v1/menus/MENU_BOARD_001/boards/1/update
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  boardData: @json {
    "bbsTtl": "수정된 제목",
    "bbsCn": "수정된 내용",
    "useYn": "Y",
    "deleteFileSqs": [],
    "changeRsn": "내용 보완"
  }
}
