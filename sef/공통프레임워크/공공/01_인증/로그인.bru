meta {
  name: 로그인
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

body:json {
  {
    "userId": "admin@sqisoft.com",
    "userPswd": "admin1234!"
  }
}

script:post-response {
  if (res.body && res.body.data) {
    bru.setEnvVar("accessToken", res.body.data.token);
    bru.setEnvVar("refreshToken", res.body.data.refreshToken);
  }
}
