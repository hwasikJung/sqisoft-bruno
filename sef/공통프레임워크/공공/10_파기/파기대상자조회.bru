meta {
  name: 파기대상자조회
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/adm/v1/user-purge/targets?type=PURGE
  body: none
  auth: inherit
}

params:query {
  type: PURGE
}

docs {
  파기 대상자(최종 로그인 후 `dormant-days` 경과) 목록 조회.
  type=PURGE (기본): 파기 대상
  type=NOTIFY: 사전통지 대상 (파기 D-`notify-before-days`)
  권한: ROLE_ADMIN
}
